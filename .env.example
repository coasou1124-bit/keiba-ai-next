# =============================================================
# データベース接続（Supabase PostgreSQL）
# =============================================================
# Supabase Dashboard → Settings → Database → Connection string
#
# DATABASE_URL : "Transaction" モード（pooled）ポート 6543
#   → API Routes (Prisma) の通常接続に使用
DATABASE_URL="postgresql://postgres.PROJECTREF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true"

# DIRECT_URL : "Session" モード（direct）ポート 5432
#   → prisma db push / migrate deploy 実行時のみ使用
DIRECT_URL="postgresql://postgres.PROJECTREF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require"

# =============================================================
# Supabase JS クライアント用（REST API / Realtime / n8n 連携）
# =============================================================
# Supabase Dashboard → Settings → API → Project URL & anon key
NEXT_PUBLIC_SUPABASE_URL="https://PROJECTREF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# サーバーサイド専用（API Routes のみ。絶対に公開しないこと）
# Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# =============================================================
# Neon PostgreSQL（現行構成から移行前に使用していた場合）
# =============================================================
# DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/dbname?sslmode=require"
# DIRECT_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require"

# =============================================================
# OpenAI API
# =============================================================
# platform.openai.com → API Keys
# gpt-4o-mini 推奨（安価: 1回 ≈ $0.001）
# OPENAI_API_KEY=sk-proj-xxxx

# =============================================================
# n8n 連携
# =============================================================
# 未設定の場合は認証スキップ（開発環境）
# 本番では必ず設定すること
N8N_API_KEY=your-strong-secret-key-here

# n8n サーバーの URL（n8n から Supabase REST API を直接叩く場合に参照）
# N8N_WEBHOOK_URL=https://your-n8n.railway.app

# =============================================================
# Discord 通知
# =============================================================
# Discord チャンネル → Edit Channel → Integrations → Webhooks
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/ID/TOKEN
# DISCORD_WEBHOOK_ALERT_URL=https://discord.com/api/webhooks/ID/TOKEN2

# =============================================================
# Anthropic / JRA-VAN（将来用）
# =============================================================
# ANTHROPIC_API_KEY=sk-ant-xxxx
# JRAVAN_AUTH_CODE=xxxx
