# =============================================================
# Neon PostgreSQL 接続設定（Vercel 環境変数に設定すること）
# =============================================================

# DATABASE_URL: 接続プール経由URL（Neon ダッシュボード → Connection string → Pooled connection）
# アプリ実行時（API Routes）に使用される
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/dbname?sslmode=require"

# DIRECT_URL: 直接接続URL（Neon ダッシュボード → Connection string → Direct connection）
# prisma db push / prisma migrate deploy 実行時に使用される
DIRECT_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require"

# =============================================================
# ローカル開発用（上記 Neon URL で統一するか、ローカル PostgreSQL を使用）
# =============================================================
# DATABASE_URL="postgresql://postgres:password@localhost:5432/keiba"
# DIRECT_URL="postgresql://postgres:password@localhost:5432/keiba"

# OpenAI API（設定すると統計ページのAI分析コメントがOpenAI生成になる。未設定時はルールベース）
# OPENAI_API_KEY=sk-xxxx

# Anthropic API（後で設定）
# ANTHROPIC_API_KEY=sk-ant-xxxx

# JRA-VAN 利用キー（後で設定）
# JRAVAN_AUTH_CODE=xxxx

# n8n連携APIキー（未設定時は認証スキップ）
N8N_API_KEY=your-secret-api-key-here
